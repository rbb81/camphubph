{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "flutter",
      "runtimeArgs": [
        "run",
        "-d",
        "web-server",
        "--web-port=3000",
        "--web-hostname=0.0.0.0",
        "--dart-define-from-file=.env"
      ],
      "port": 3000
    }
  ]
}
